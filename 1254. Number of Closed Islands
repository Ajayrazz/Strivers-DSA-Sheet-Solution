class Solution {
    public int closedIsland(int[][] grid) {
        int m = grid.length, n = grid[0].length;
        int[] dx = {1, 0, 0, -1};
        int[] dy = {0, -1, 1, 0};
        //Remove boundary connected lands
        for (int i = 0; i < m; i++) {
            dfs(grid, i, 0, dx, dy);
            dfs(grid, i, n - 1, dx, dy);
        }
        for (int j = 0; j < n; j++) {
            dfs(grid, 0, j, dx, dy);
            dfs(grid, m - 1, j, dx, dy);
        }

        //Count closed islands
        int count = 0;
        for (int i = 1; i < m - 1; i++) {
            for (int j = 1; j < n - 1; j++) {
                if (grid[i][j] == 0) {
                    count++;
                    dfs(grid, i, j, dx, dy);
                }
            }
        }

        return count;
    }

    private void dfs(int[][] grid, int row, int col, int[] dx, int[] dy) {
        // Base case
        if (row < 0 || col < 0 || row >= grid.length || col >= grid[0].length || grid[row][col] == 1) {
            return;
        }

        // Mark as visited
        grid[row][col] = 1;
        for (int index = 0; index < 4; index++) {
            int nRow = row + dx[index];
            int nCol = col + dy[index];
            dfs(grid, nRow, nCol, dx, dy);
        }
    }
}
