class DisjointSet {
    List<Integer> parent = new ArrayList<>();
    List<Integer> size = new ArrayList<>();

    public DisjointSet(int n){
        for(int i = 0; i < n; i++){
            size.add(1);
            parent.add(i);
        }
    }

    // find_ulp function
    public int find_ulp(int node){
        if(node == parent.get(node)) return node;
        int ulp = find_ulp(parent.get(node));
        parent.set(node, ulp);
        return parent.get(node);
    }

    // unionBySize function
    public void unionBySize(int u, int v){
        int ulp_u = find_ulp(u);
        int ulp_v = find_ulp(v);
        if(ulp_u == ulp_v) return;

        if(size.get(ulp_u) < size.get(ulp_v)){
            parent.set(ulp_u, ulp_v);
            size.set(ulp_v, size.get(ulp_u) + size.get(ulp_v));
        }
        else {
            parent.set(ulp_v, ulp_u);
            size.set(ulp_u, size.get(ulp_u) + size.get(ulp_v));
        }
    }
}

class Solution {
    public boolean containsCycle(char[][] grid) {
        int rows = grid.length, cols = grid[0].length;
        DisjointSet ds = new DisjointSet(rows * cols);

        for (int i = 0; i < rows; i++) {
            for (int j = 0; j < cols; j++) {
                int node = i * cols + j;
                if (j + 1 < cols && grid[i][j] == grid[i][j + 1]) {
                    int adj = i * cols + (j + 1);
                    if (ds.find_ulp(node) == ds.find_ulp(adj)) {
                        return true; // cycle detected
                    }
                    ds.unionBySize(node, adj);
                }

                if (i + 1 < rows && grid[i][j] == grid[i + 1][j]) {
                    int adj = (i + 1) * cols + j;
                    if (ds.find_ulp(node) == ds.find_ulp(adj)) {
                        return true; // cycle detected
                    }
                    ds.unionBySize(node, adj);
                }
            }
        }
        return false;
    }
}
