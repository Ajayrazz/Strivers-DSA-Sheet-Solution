class Solution {
    public int minFlips(String str) {
        int length = str.length();
        int[][] prefixCost = new int[length][2];
        // Build prefix cost array
        for (int i = 0; i < length; i++) {
            char currentChar = str.charAt(i);
            prefixCost[i][0] = (i == 0 ? 0 : prefixCost[i - 1][1]) + (currentChar == '1' ? 1 : 0);
            prefixCost[i][1] = (i == 0 ? 0 : prefixCost[i - 1][0]) + (currentChar == '0' ? 1 : 0);
        }
        int minimumFlips = Math.min(prefixCost[length - 1][0], prefixCost[length - 1][1]);
        // Only needed when length is odd
        if (length % 2 == 1) {
            int[][] suffixCost = new int[length][2];
            // Build suffix cost array
            for (int i = length - 1; i >= 0; i--) {
                char currentChar = str.charAt(i);
                suffixCost[i][0] = (i == length - 1 ? 0 : suffixCost[i + 1][1]) + (currentChar == '1' ? 1 : 0);
                suffixCost[i][1] = (i == length - 1 ? 0 : suffixCost[i + 1][0]) + (currentChar == '0' ? 1 : 0);
            }

            // Try every split position
            for (int split = 0; split < length - 1; split++) {
                minimumFlips = Math.min(minimumFlips, prefixCost[split][0] + suffixCost[split + 1][0]);
                minimumFlips = Math.min(minimumFlips, prefixCost[split][1] + suffixCost[split + 1][1]);
            }
        }
        return minimumFlips;
    }
}
