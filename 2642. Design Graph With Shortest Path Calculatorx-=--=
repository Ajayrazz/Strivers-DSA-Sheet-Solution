class Pair {
    int first, second;
    public Pair(int first, int second){
        this.first = first;
        this.second = second;
    }
}

class Graph {
    List<List<Pair>> adj = new ArrayList<>();
    int V;
    public Graph(int n, int[][] edges) {
        V = n;
        for(int i = 0; i < n; i++){
            adj.add(new ArrayList<>());
        }

        for(int[] edge : edges){
            int u = edge[0], v = edge[1], wt = edge[2];
            adj.get(u).add(new Pair(v, wt));
        }
    }
    
    public void addEdge(int[] edge) {
        int u = edge[0], v = edge[1], wt = edge[2];
        adj.get(u).add(new Pair(v, wt));
    }
    
    public int shortestPath(int node1, int node2) {
        PriorityQueue<Pair> pq = new PriorityQueue<>((a, b) -> Integer.compare(a.second, b.second));
        pq.add(new Pair(node1, 0));
        int[] dist = new int[V];
        Arrays.fill(dist, Integer.MAX_VALUE);
        dist[node1] = 0;
        //bfs
        while(!pq.isEmpty()){
            int node = pq.peek().first;
            int edW = pq.peek().second;
            pq.poll();

            for(Pair current : adj.get(node)){
                int adjnode = current.first;
                int distance = current.second;

                if(distance + edW < dist[adjnode]){
                    dist[adjnode] = distance + edW;
                    pq.add(new Pair(adjnode, dist[adjnode]));
                }
            }
        }

        return dist[node2] == Integer.MAX_VALUE ? -1 : dist[node2];
    }
}

