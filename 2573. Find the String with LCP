class Solution {
    public String findTheString(int[][] lcp) {
        int n = lcp.length;
        char[] ans = new char[n];
        if (!buildString(ans, lcp)) return "";
        if (!isValid(ans, lcp)) return "";
        return String.valueOf(ans);
    }

    private boolean buildString(char[] ans, int[][] lcp) {
        int n = ans.length;
        char nextChar = 'a';
        for (int i = 0; i < n; i++) {
            if (ans[i] == 0) {
                if (nextChar > 'z') return false;
                fillSameChars(ans, lcp, i, nextChar);
                nextChar++;
            }
        }
        return true;
    }

    private void fillSameChars(char[] ans, int[][] lcp, int index, char ch) {
        ans[index] = ch;
        for (int j = index + 1; j < ans.length; j++) {
            if (lcp[index][j] > 0) {
                ans[j] = ch;
            }
        }
    }

    private boolean isValid(char[] ans, int[][] lcp) {
        int n = ans.length;
        for (int i = n - 1; i >= 0; i--) {
            for (int j = n - 1; j >= 0; j--) {
                if (ans[i] == ans[j]) {
                    if (!checkMatch(ans, lcp, i, j)) return false;
                } else {
                    if (lcp[i][j] != 0) return false;
                }
            }
        }
        return true;
    }

    private boolean checkMatch(char[] ans, int[][] lcp, int i, int j) {
        int n = ans.length;
        if (i == n - 1 || j == n - 1) {
            return lcp[i][j] == 1;
        }
        return lcp[i][j] == lcp[i + 1][j + 1] + 1;
    }
}
