class Solution {
    public boolean containsNearbyAlmostDuplicate(int[] nums, int indexDiff, int valueDiff) {
        if (nums == null || nums.length == 0 || valueDiff < 0) {
            return false;
        }
        HashMap<Long, Long> map = new HashMap<>();
        long size = (long) valueDiff + 1;
        for (int i = 0; i < nums.length; i++) {
            long num = nums[i];
            long idx = getIndex(num, size);
            // same bucket
            if (map.containsKey(idx)) {
                return true;
            }
            // left bucket
            if (map.containsKey(idx - 1) &&
                Math.abs(num - map.get(idx - 1)) <= valueDiff) {
                return true;
            }
            // right bucket
            if (map.containsKey(idx + 1) &&
                Math.abs(num - map.get(idx + 1)) <= valueDiff) {
                return true;
            }
            map.put(idx, num);
            // remove old element (sliding window)
            if (i >= indexDiff) {
                long old = nums[i - indexDiff];
                long old_idx = getIndex(old, size);
                map.remove(old_idx);
            }
        }

        return false;
    }

    private long getIndex(long num, long size) {
        if (num >= 0) {
            return num / size;
        } else {
            return ((num + 1) / size) - 1;
        }
    }
}
