class Solution {
    public int mod = (int) 1e9 + 7;
    public int xorAfterQueries(int[] nums, int[][] queries) {
        for(int[] q : queries){
            int l = q[0], r = q[1], k = q[2], v = q[3];
            for(int i = l; i <= r; i += k){
                nums[i] = (int) (((long) nums[i] * v) % mod);
            }
        }

        int result = nums[0];
        for(int i = 1; i < nums.length; i++){
            result ^= nums[i];
        }

        return result;
    }
}
