class Solution {
    public int minSwaps(int[][] grid) {
        int n = grid.length;
        int[] zeros = new int[n];
        int count = 0;
        for (int i = 0; i < n; i++) {
            count = 0;
            for (int j = grid[0].length - 1; j >= 0; j--) {
                if (grid[i][j] == 0) {
                    count++;
                } else break;
            }
            zeros[i] = count;
        }
        int swaps = 0;
        for (int i = 0; i < n - 1; i++) {
            int need = n - i - 1;
            if (zeros[i] >= need) continue;
            int pos = -1;
            for (int j = i; j < n; j++) {
                if (zeros[j] >= need) {
                    pos = j;
                    break;
                }
            }
            if (pos == -1) return -1;
            int temp = zeros[pos];
            for (int k = pos; k > i; k--) {
                zeros[k] = zeros[k - 1];
            }
            zeros[i] = temp;
            swaps += pos - i;
        }

        return swaps;
    }
}
