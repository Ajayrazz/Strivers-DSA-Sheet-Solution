class Solution {
    public int[] searchRange(int[] nums, int target) {
        int[] result = {-1, -1};
        int left = Helper(nums, target, true);
        int right = Helper(nums, target, false);
        result[0] = left;
        result[1] = right;
        return result;
    }

    //Helper Function
    public int Helper(int[] nums, int target, boolean isSearching){
        int left = 0, right = nums.length - 1, idx = -1;
        while(left <= right){
            int mid = left + (right - left) / 2;
            if(nums[mid] > target){
                right = mid - 1;
            }
            else if(nums[mid] < target){
                left = mid + 1;
            }
            else {
                idx = mid;
                if(isSearching){
                    right = mid - 1;
                }
                else {
                    left = mid + 1;
                }
            }
        }
        return idx;
    }
}
