class Solution {
    public List<Integer> survivedRobotsHealths(int[] positions, int[] healths, String directions) {
        int len = positions.length;
        int[][] data = new int[len][2];
        for (int i = 0; i < len; i++) {
            data[i] = new int[]{positions[i], i};
        }
        Arrays.sort(data, Comparator.comparingInt(a -> a[0]));
        int[] hp = new int[len];
        char[] move = new char[len];
        for (int i = 0; i < len; i++) {
            int idx = data[i][1];
            hp[i] = healths[idx];
            move[i] = directions.charAt(idx);
        }
        Deque<Integer> st = new ArrayDeque<>();
        for (int i = 0; i < len; i++) {
            if (move[i] == 'R') {
                st.push(i);
                continue;
            }
            while (!st.isEmpty() && hp[i] > 0) {
                int top = st.peek();
                if (hp[top] < hp[i]) {
                    st.pop();
                    hp[i]--;
                    hp[top] = 0;
                } 
                else if (hp[top] > hp[i]) {
                    hp[top]--;
                    hp[i] = 0;
                } 
                else {
                    st.pop();
                    hp[top] = 0;
                    hp[i] = 0;
                }
            }
        }
        int[] ansArr = new int[len];
        for (int i = 0; i < len; i++) {
            int idx = data[i][1];
            ansArr[idx] = hp[i];
        }
        List<Integer> ans = new ArrayList<>();
        for (int val : ansArr) {
            if (val > 0) ans.add(val);
        }
        return ans;
    }
}
