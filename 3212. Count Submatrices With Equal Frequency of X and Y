class Solution {
    public int numberOfSubmatrices(char[][] grid) {
        int n = grid.length;
        int m = grid[0].length;
        int[][] prefix = new int[n][m];
        boolean[][] hasX = new boolean[n][m];
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < m; j++) {
                if (grid[i][j] == 'X') {
                    prefix[i][j] = 1;
                } else if (grid[i][j] == 'Y') {
                    prefix[i][j] = -1;
                } else {
                    prefix[i][j] = 0;
                }
            }
        }

        int count = 0;
        if (grid[0][0] == 'X') {
            hasX[0][0] = true;
        }

        for (int i = 1; i < n; i++) {
            hasX[i][0] = (grid[i][0] == 'X') || hasX[i - 1][0];
            prefix[i][0] += prefix[i - 1][0];
            if (hasX[i][0] && prefix[i][0] == 0) {
                count++;
            }
        }

        for (int j = 1; j < m; j++) {
            hasX[0][j] = (grid[0][j] == 'X') || hasX[0][j - 1];
            prefix[0][j] += prefix[0][j - 1];
            if (hasX[0][j] && prefix[0][j] == 0) {
                count++;
            }
        }

        for (int i = 1; i < n; i++) {
            for (int j = 1; j < m; j++) {
                hasX[i][j] = (grid[i][j] == 'X') || hasX[i - 1][j] || hasX[i][j - 1];
                prefix[i][j] = prefix[i][j] + prefix[i - 1][j] + prefix[i][j - 1] - prefix[i - 1][j - 1];

                if (hasX[i][j] && prefix[i][j] == 0) {
                    count++;
                }
            }
        }

        return count;
    }
}
