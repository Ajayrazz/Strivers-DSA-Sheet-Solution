class Solution {
    public char findKthBit(int n, int k) {
        boolean invert = false;
        while (n > 1) {
            int length = (1 << n) - 1;
            int mid = (length / 2) + 1;
            if (k == mid) {
                return invert ? '0' : '1';
            }
            if (k > mid) {
                k = mid - (k - mid);
                invert = !invert;
            }
            n--;
        }

        return invert ? '1' : '0';
    }
}
